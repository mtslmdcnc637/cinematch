# ─── SUPABASE ───────────────────────────────────────
VITE_SUPABASE_URL="YOUR_SUPABASE_URL"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# ─── STRIPE (Server-side only — set in Supabase Edge Function Secrets) ──
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_MONTHLY=price_...
# STRIPE_PRICE_QUARTERLY=price_...
# STRIPE_PRICE_ANNUAL=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── OPENROUTER (Server-side only — set in Supabase Edge Function Secrets) ──
# OPENROUTER_API_KEY=sk-or-...

# ─── TMDB (Server-side only — set in Supabase Edge Function Secrets) ──
# TMDB_API_KEY=...
# Note: tmdb-proxy edge function uses verify_jwt = true (default)
# The frontend sends the user's Bearer token in the Authorization header

# ─── GOOGLE ANALYTICS (Client-side) ─────────────────
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# ─── WEB PUSH NOTIFICATIONS (Client-side) ───────────
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# ─── APP URL ─────────────────────────────────────────
# APP_URL=https://cinematch.app

# ─── SUPABASE ADMIN (Server-side only — for Edge Functions) ──
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_ANON_KEY=eyJ...
